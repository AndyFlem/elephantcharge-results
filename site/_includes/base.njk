<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{% if title %}{{ title }} — {% endif %}Elephant Charge Results</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&display=swap">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@picocss/pico@2/css/pico.min.css">
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
  <link rel="stylesheet" href="/css/app.css">
</head>
<body>
  <header class="container-fluid site-header">
    <nav>
      <ul>
        <li>
          <a href="/" class="site-brand">
            <img src="/ec-logo.png" alt="Elephant Charge" class="site-logo">
            <span class="site-title">
              Elephant Charge
              <span>Results Archive</span>
            </span>
          </a>
        </li>
      </ul>
      <ul>
        <li><a href="/">Charges</a></li>
        <li><a href="/teams/">Teams</a></li>
        <li><a href="/cars/">Cars</a></li>
        <li><a href="/beneficiaries/">Beneficiaries</a></li>
      </ul>
    </nav>
  </header>

  <main class="container">
    {{ content | safe }}
  </main>

  <footer class="container-fluid site-footer">
    <small>
      Elephant Charge results archive &mdash; data updated annually after each event.<br>
      <a href="https://elephantcharge.org/" target="_blank" rel="noopener">elephantcharge.org</a>
    </small>
  </footer>
</body>
</html>

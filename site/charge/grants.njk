---
pagination:
  data: charges
  size: 1
  alias: charge
permalink: "/charge/{{ charge.charge_ref }}/grants/"
layout: base.njk
---

<section class="charge-header">
  <p class="charge-meta"><a href="/">← All charges</a></p>
  <h1>{{ charge.charge_name }}</h1>
  <p class="charge-meta">{{ charge.charge_date | date }} · 📍 {{ charge.location }}</p>

  <nav class="page-tabs">
    <a href="/charge/{{ charge.charge_ref }}/">Results</a>
    <a href="/charge/{{ charge.charge_ref }}/checkpoints/">Checkpoints</a>
    <a href="/charge/{{ charge.charge_ref }}/awards/">Awards</a>
    <a href="/charge/{{ charge.charge_ref }}/grants/" class="active">Grants</a>
    {% if charge.has_gps_tracks %}
    <a href="/charge/{{ charge.charge_ref }}/map/">🗺 Map</a>
    {% endif %}
  </nav>
</section>

<section>
  <h2>Conservation Grants</h2>
  <p class="small muted">
    Funds distributed to conservation organisations from the {{ charge.charge_ref }} charge.
  </p>
  <div style="overflow-x:auto">
  <table>
    <thead>
      <tr>
        <th>Organisation</th>
        <th>Amount (ZMW)</th>
        <th>Purpose</th>
      </tr>
    </thead>
    <tbody>
      {% set total = 0 %}
      {% for grant in charge.grants %}
      <tr>
        <td><a href="/beneficiaries/#{{ grant.beneficiary_id }}">{{ grant.beneficiary_name }}</a></td>
        <td class="distance">{{ grant.grant_kwacha | number }}</td>
        <td class="small muted">{{ grant.description or '—' }}</td>
      </tr>
      {% set total = total + grant.grant_kwacha %}
      {% endfor %}
    </tbody>
    <tfoot>
      <tr>
        <th>Total</th>
        <th class="distance">{{ charge.raised_local | number }}</th>
        <th></th>
      </tr>
    </tfoot>
  </table>
  </div>
</section>

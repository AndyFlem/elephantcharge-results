---
pagination:
  data: charges
  size: 1
  alias: charge
permalink: "/charge/{{ charge.charge_ref }}/awards/"
layout: base.njk
---

<section class="charge-header">
  <p class="charge-meta"><a href="/">← All charges</a></p>
  <h1>{{ charge.charge_name }}</h1>
  <p class="charge-meta">{{ charge.charge_date | date }} · 📍 {{ charge.location }}</p>

  <nav class="page-tabs">
    <a href="/charge/{{ charge.charge_ref }}/">Results</a>
    <a href="/charge/{{ charge.charge_ref }}/checkpoints/">Checkpoints</a>
    <a href="/charge/{{ charge.charge_ref }}/awards/" class="active">Awards</a>
    {% if charge.grants.length %}
    <a href="/charge/{{ charge.charge_ref }}/grants/">Grants</a>
    {% endif %}
    {% if charge.has_gps_tracks %}
    <a href="/charge/{{ charge.charge_ref }}/map/">🗺 Map</a>
    {% endif %}
  </nav>
</section>

<section>
  <h2>Awards</h2>
  <div>
    {% for aw in charge.award_winners %}
    <div class="award-winner">
      <div class="award-ordinal">{{ aw.ordinal }}</div>
      <div>
        <div class="award-name">{{ aw.name }}</div>
        <div class="award-winner-name">
          {% if aw.winner %}
            🏆 Car {{ aw.winner.car_no }} — {{ aw.winner.entry_name }}
            {% if aw.type_ref == 'DISTANCE' and aw.winner.value != null %}
              ({{ aw.winner.value | km }})
            {% elif aw.type_ref == 'PLEDGE' and aw.winner.value != null %}
              ({{ aw.winner.value | dollars }})
            {% endif %}
          {% else %}
            <span class="muted">No eligible entry</span>
          {% endif %}
        </div>
        {% if aw.class_name or aw.category %}
        <div class="small muted">
          {% if aw.class_name %}{{ aw.class_name }}{% endif %}
          {% if aw.class_name and aw.category %} · {% endif %}
          {% if aw.category %}{{ aw.category }}{% endif %}
        </div>
        {% endif %}
      </div>
    </div>
    {% endfor %}
  </div>
</section>
